# Neon Postgres — pooled connection (runtime / serverless)
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# Neon Postgres — direct connection (migrations / db push)
DATABASE_URL_UNPOOLED=postgresql://USER:PASSWORD@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

PORT=3001

# Comma-separated UI origins (no quotes)
CORS_ORIGIN=https://recruit-pro-five-v2.vercel.app,http://localhost:5173

# Allow any *.vercel.app origin (useful for preview deployments)
CORS_ALLOW_VERCEL=true
